# Database (Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lumiere_db
DB_USER=postgres
DB_PASS=postgres

# App
APP_HOST=0.0.0.0:8080
APP_PORT=8080

# Security
JWT_SECRET=replace_with_secure_random_hex

# DB options (tune as needed)
# DB_SSLMODE: disable | require
DB_SSLMODE=disable
# maximum open connections
DB_MAX_OPEN_CONNS=25
# maximum idle connections
DB_MAX_IDLE_CONNS=25
# connection max lifetime in minutes
DB_CONN_MAX_LIFETIME_MIN=15

# Redis cache (optional; the API falls back to PostgreSQL when disabled)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# For Vercel + Upstash REST, these variables automatically enable the cache.
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token
